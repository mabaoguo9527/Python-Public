# ============================================================
# Python 大仓 (monorepo) .gitignore
# 适用于多子项目/多包结构的 Python 仓库
# ============================================================

# ---------- Python 字节码与缓存 ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---------- 虚拟环境 ----------
.venv/
venv/
env/
ENV/
.env/
.venv*/
pip-wheel-metadata/

# 例外：保留示例环境文件模板
!.env.example

# ---------- 打包与构建产物 ----------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl
sdist/
parts/
bin/
var/
include/

# ---------- 测试与覆盖率 ----------
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/
nosetests.xml
.hypothesis/
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json
dmypy.json

# ---------- 类型检查 / Lint ----------
.mypy_cache/
.pyre/
.pytype/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- 日志 ----------
*.log
logs/
*.log.*

# ---------- 运行时 / 数据 ----------
*.pid
*.seed
*.sqlite3
*.db
data/local/

# ---------- 文档构建 ----------
docs/_build/
site/

# ---------- IDE / 编辑器 ----------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ---------- 操作系统 ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.Library/Caches/
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- 其他 ----------
*.bak
*.tmp
tmp/
